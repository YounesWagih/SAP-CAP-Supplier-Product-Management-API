{
  "name": "cap-task",
  "version": "1.0.0",
  "description": "SAP CAP-based Supplier Product Management API",
  "scripts": {
    "start": "cds serve",
    "watch": "cds watch",
    "build": "tsc -p tsconfig.build.json",
    "build:all": "tsc",
    "watch:ts": "tsc --watch",
    "build:cds": "cds build",
    "deploy": "cds deploy"
  },
  "dependencies": {
    "@sap/cds": "^8.9.9",
    "@sap/cds-sqlite": "^1.0.0",
    "express": "^4.18.2",
    "sqlite3": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite"
      }
    }
  }
}